-- Creo tabla clientes
CREATE TABLE Clientes (
	ID_cliente INTEGER PRIMARY KEY, -- Elijo un tipo de dato numerico y convierto este campo en la llave primaria
	nombre VARCHAR(100), -- El tipo de dato es texto con limitación de 100 caracteres
	perfil_bio TEXT, -- Para textos largos
	fecha_registro DATE -- Para fechas
)

CREATE TABLE Productos (
	ID_Producto INTEGER PRIMARY KEY, -- Lo mismo que el ID de cliente en la tabla clientes
	Descripcion VARCHAR(255), -- Texto con limitación de 255 caractees
	Precio DECIMAL (10,2), -- Numero decimal con limitación de 10 digitos y 2 decimales
	Activo BOOL -- Tipo booleano (True o False)
)

